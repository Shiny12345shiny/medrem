# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=5000
NODE_ENV=development
BASE_URL=http://localhost:5000

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
MONGO_URI=mongodb://localhost:27017/medicine-reminder
# For MongoDB Atlas, use:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/medicine-reminder?retryWrites=true&w=majority

# ==========================================
# JWT CONFIGURATION
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-key
JWT_REFRESH_EXPIRE=30d

# ==========================================
# EMAIL CONFIGURATION (Nodemailer)
# ==========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=Smart Medicine Reminder <noreply@medicinereminder.com>

# For SendGrid (alternative):
# SENDGRID_API_KEY=your-sendgrid-api-key

# ==========================================
# EXPO PUSH NOTIFICATIONS
# ==========================================
EXPO_ACCESS_TOKEN=your-expo-access-token-from-expo-dev
# Get from: https://expo.dev/accounts/[account]/settings/access-tokens

# ==========================================
# SOCKET.IO CONFIGURATION
# ==========================================
SOCKET_PORT=5001
SOCKET_CORS_ORIGIN=*

# ==========================================
# FILE UPLOAD CONFIGURATION
# ==========================================
MAX_FILE_SIZE=10485760
# 10MB in bytes (10 * 1024 * 1024)
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# ==========================================
# NOTIFICATION SETTINGS
# ==========================================
REMINDER_ADVANCE_TIME=15
# Minutes before scheduled time to send reminder
ESCALATION_INTERVAL=5
# Minutes between escalation reminders
MAX_ESCALATION_ATTEMPTS=3
# Maximum number of reminder escalations

# ==========================================
# REFILL ALERT SETTINGS
# ==========================================
LOW_STOCK_THRESHOLD=5
# Number of doses remaining to trigger refill alert
REFILL_REMINDER_DAYS=3
# Days before stock runs out to send alert

# ==========================================
# CONSULTATION SETTINGS
# ==========================================
CONSULTATION_DURATION=30
# Default consultation duration in minutes
NEARBY_DOCTOR_RADIUS=10
# Radius in kilometers to search for nearby doctors

# ==========================================
# SECURITY SETTINGS
# ==========================================
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW=15
# Rate limit window in minutes
RATE_LIMIT_MAX_REQUESTS=100
# Max requests per window

# ==========================================
# CORS SETTINGS
# ==========================================
CORS_ORIGIN=*
# In production, set to specific domains

# ==========================================
# TWILIO (Optional - for SMS notifications)
# ==========================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# ==========================================
# REDIS (Optional - for session/cache)
# ==========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info
# Options: error, warn, info, http, verbose, debug, silly

# ==========================================
# ADMIN CREDENTIALS (Initial Setup)
# ==========================================
ADMIN_EMAIL=admin@medicinereminder.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=System Administrator

# ==========================================
# GOOGLE MAPS API (for location services)
# ==========================================
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ==========================================
# AWS S3 (Optional - for file storage)
# ==========================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=medicine-reminder-files

# ==========================================
# FIREBASE (Optional - alternative notifications)
# ==========================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# ==========================================
# SENTRY (Optional - error tracking)
# ==========================================
SENTRY_DSN=your-sentry-dsn

# ==========================================
# FRONTEND URL (for email links, etc.)
# ==========================================
FRONTEND_URL=exp://192.168.1.100:8081
# Replace with your local IP when testing with Expo Go

# ==========================================
# VIDEO CALL SETTINGS (WebRTC)
# ==========================================
TURN_SERVER_URL=turn:your-turn-server.com:3478
TURN_USERNAME=your-turn-username
TURN_CREDENTIAL=your-turn-credential
STUN_SERVER_URL=stun:stun.l.google.com:19302

# ==========================================
# TIMEZONE
# ==========================================
TZ=Asia/Kolkata
# Set to your local timezone

# ==========================================
# BACKUP SETTINGS
# ==========================================
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
# Cron format: daily at 2 AM
BACKUP_RETENTION_DAYS=30

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_VIDEO_CONSULTATIONS=true
ENABLE_HEALTH_RECORDS=true
ENABLE_NEARBY_DOCTORS=true

